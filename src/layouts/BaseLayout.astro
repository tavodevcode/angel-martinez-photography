---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import type { Locale } from '@/lib/content/types';
import { getLocaleAlternates } from '@/lib/i18n';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  /** Ruta de la imagen para Open Graph/Twitter (relativa al site). Default: /og-image.jpg */
  image?: string;
  /** Tipo Open Graph. Default: 'website' */
  ogType?: string;
}

const { title, description, locale = 'es', image = '/og-image.jpg', ogType = 'website' } = Astro.props;

const SITE_NAME = 'Angel Martinez Photography';
// Astro.site viene de astro.config (site); fallback defensivo por si faltara.
const siteOrigin = Astro.site ?? new URL('https://photos.angelmartinez.local');
const canonical = new URL(Astro.url.pathname, siteOrigin);
const ogImage = new URL(image, siteOrigin);
const ogLocale = locale === 'en' ? 'en_US' : 'es_ES';
const ogLocaleAlt = locale === 'en' ? 'es_ES' : 'en_US';

// Alternates es/en para que Google no trate las dos versiones como duplicado.
const alt = getLocaleAlternates(Astro.url.pathname);
const alternateLinks = [
  { hreflang: 'es', href: new URL(alt.es, siteOrigin).href },
  { hreflang: 'en', href: new URL(alt.en, siteOrigin).href },
  { hreflang: 'x-default', href: new URL(alt.es, siteOrigin).href },
];

// Datos estructurados: negocio de fotografía para búsqueda local / rich results.
// Sin dirección ni teléfono reales todavía — completar cuando existan.
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': siteOrigin.href,
  name: SITE_NAME,
  description,
  url: siteOrigin.href,
  image: ogImage.href,
  areaServed: 'Ciudad de México',
  founder: { '@type': 'Person', name: 'Angel Martinez' },
  sameAs: ['https://instagram.com', 'https://behance.net'],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#000000" />
    <link rel="canonical" href={canonical.href} />
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href} />
    ))}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* Open Graph — miniatura al compartir en WhatsApp/Facebook/Instagram */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={SITE_NAME} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <ClientRouter fallback="animate" />
    <script is:inline>
      // Marca JS disponible antes del primer paint: los estados ocultos de
      // [data-reveal]/[data-rise] solo aplican con JS (si no, todo visible).
      document.documentElement.classList.add('has-js');
    </script>
    <slot name="head" />
  </head>
  <body class="bg-ink text-fog">
    <slot />
    <script>
      // Revelado al hacer scroll. Se re-ejecuta en cada navegación (view
      // transitions) vía astro:page-load, que dispara también en la carga inicial.
      const initReveal = () => {
        const targets = document.querySelectorAll('[data-reveal]:not(.is-visible), [data-rise]:not(.is-visible)');
        if (!targets.length) return;
        if (!('IntersectionObserver' in window)) {
          targets.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        // Los elementos [data-rise] arrancan trasladados 115% hacia abajo, lo que
        // desplazaría su propia caja fuera del área observada. Por eso observamos
        // el contenedor-máscara estable (overflow-hidden) y revelamos su hijo.
        const map = new WeakMap();
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              const target = map.get(entry.target) || entry.target;
              target.classList.add('is-visible');
              obs.unobserve(entry.target);
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        const viewportBottom = window.innerHeight * 0.92; // espeja el rootMargin -8%
        targets.forEach((el) => {
          const trigger = el.hasAttribute('data-rise') && el.parentElement ? el.parentElement : el;
          // Lo que ya está en viewport se revela de inmediato, sin esperar el
          // primer callback del observer; el IO queda solo para lo below-fold.
          const rect = trigger.getBoundingClientRect();
          if (rect.top < viewportBottom && rect.bottom > 0) {
            el.classList.add('is-visible');
            return;
          }
          map.set(trigger, el);
          io.observe(trigger);
        });
      };

      // En carga inicial revela de inmediato; tras una navegación espera a que
      // la view transition (0.34s) termine para no competir con ella por frames
      // (importante en móviles de alta resolución).
      // Rastreo de la ruta previa (sessionStorage) para que el enlace "volver"
      // pueda restaurar el scroll. El botón atrás del navegador ya restaura la
      // posición vía ClientRouter; un <a href> de "volver" es navegación hacia
      // adelante y caería al top. Si detectamos que venimos justo de esa página,
      // hacemos history.back() para reusar esa restauración.
      const trackNav = () => {
        try {
          const current = sessionStorage.getItem('nav:current');
          sessionStorage.setItem('nav:prev', current ?? '');
          sessionStorage.setItem('nav:current', location.pathname);
        } catch {
          /* sessionStorage no disponible (modo privado): degrada a navegación normal */
        }
      };
      const stripSlash = (path: string) => path.replace(/\/+$/, '') || '/';
      // Captura para correr antes del listener del ClientRouter y poder cancelarlo.
      document.addEventListener(
        'click',
        (event) => {
          const link = event.target instanceof Element ? event.target.closest('[data-back-link]') : null;
          if (!link) return;
          if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
          let prev = '';
          try {
            prev = sessionStorage.getItem('nav:prev') ?? '';
          } catch {
            /* noop */
          }
          const target = new URL(link.getAttribute('href') ?? '/', location.origin).pathname;
          if (prev && stripSlash(prev) === stripSlash(target) && window.history.length > 1) {
            event.preventDefault();
            window.history.back();
          }
        },
        { capture: true },
      );

      let navigated = false;
      document.addEventListener('astro:after-swap', () => {
        navigated = true;
        // El ClientRouter reemplaza los atributos de <html> con los del nuevo
        // documento y los scripts inline no se re-ejecutan: hay que restaurar
        // la marca has-js o los estados ocultos de [data-reveal] no aplican.
        document.documentElement.classList.add('has-js');
      });
      document.addEventListener('astro:page-load', () => {
        trackNav();
        if (navigated) window.setTimeout(initReveal, 360);
        else initReveal();
      });
    </script>
  </body>
</html>
