---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import type { Locale } from '@/lib/content/types';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
}

const { title, description, locale = 'es' } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter fallback="animate" />
    <script is:inline>
      // Marca JS disponible antes del primer paint: los estados ocultos de
      // [data-reveal]/[data-rise] solo aplican con JS (si no, todo visible).
      document.documentElement.classList.add('has-js');
    </script>
    <slot name="head" />
  </head>
  <body class="bg-ink text-fog">
    <slot />
    <script>
      // Revelado al hacer scroll. Se re-ejecuta en cada navegación (view
      // transitions) vía astro:page-load, que dispara también en la carga inicial.
      const initReveal = () => {
        const targets = document.querySelectorAll('[data-reveal]:not(.is-visible), [data-rise]:not(.is-visible)');
        if (!targets.length) return;
        if (!('IntersectionObserver' in window)) {
          targets.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        // Los elementos [data-rise] arrancan trasladados 115% hacia abajo, lo que
        // desplazaría su propia caja fuera del área observada. Por eso observamos
        // el contenedor-máscara estable (overflow-hidden) y revelamos su hijo.
        const map = new WeakMap();
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              const target = map.get(entry.target) || entry.target;
              target.classList.add('is-visible');
              obs.unobserve(entry.target);
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        const viewportBottom = window.innerHeight * 0.92; // espeja el rootMargin -8%
        targets.forEach((el) => {
          const trigger = el.hasAttribute('data-rise') && el.parentElement ? el.parentElement : el;
          // Lo que ya está en viewport se revela de inmediato, sin esperar el
          // primer callback del observer; el IO queda solo para lo below-fold.
          const rect = trigger.getBoundingClientRect();
          if (rect.top < viewportBottom && rect.bottom > 0) {
            el.classList.add('is-visible');
            return;
          }
          map.set(trigger, el);
          io.observe(trigger);
        });
      };

      // En carga inicial revela de inmediato; tras una navegación espera a que
      // la view transition (0.34s) termine para no competir con ella por frames
      // (importante en móviles de alta resolución).
      let navigated = false;
      document.addEventListener('astro:after-swap', () => {
        navigated = true;
        // El ClientRouter reemplaza los atributos de <html> con los del nuevo
        // documento y los scripts inline no se re-ejecutan: hay que restaurar
        // la marca has-js o los estados ocultos de [data-reveal] no aplican.
        document.documentElement.classList.add('has-js');
      });
      document.addEventListener('astro:page-load', () => {
        if (navigated) window.setTimeout(initReveal, 360);
        else initReveal();
      });
    </script>
  </body>
</html>
