---
import SiteScaffold from '@/components/layout/SiteScaffold.astro';
import AboutSection from '@/components/sections/AboutSection.astro';
import ContactSection from '@/components/sections/ContactSection.astro';
import GallerySection from '@/components/sections/GallerySection.astro';
import PageHeader from '@/components/sections/PageHeader.astro';
import { createContentProvider } from '@/lib/content';

const provider = createContentProvider();
const content = await provider.getMarketingContent('en');
---

<SiteScaffold
  title={`${content.brand} | About`}
  description="Meet the visual direction, process, and creative approach of our photography studio."
  brand={content.brand}
  nav={content.nav}
  locale="en"
  homeHref="/en/"
  ctaLabel={content.hero.ctaLabel}
  ctaHref={content.hero.ctaHref}
  pageTone="inner"
>
  <PageHeader
    eyebrow="Editorial navigation"
    title="About"
    subtitle="Creative direction, visual production, and a reliable workflow to deliver publication-ready assets."
  />
  <AboutSection about={content.about} />
  <GallerySection gallery={content.gallery} />
  <ContactSection contact={content.contact} nav={content.nav} />
</SiteScaffold>
