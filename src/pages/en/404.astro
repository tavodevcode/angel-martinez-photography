---
import SiteScaffold from '@/components/layout/SiteScaffold.astro';
import { createContentProvider } from '@/lib/content';

const provider = createContentProvider();
const content = await provider.getMarketingContent('en');
---

<SiteScaffold
  title={`${content.brand} | Page not found`}
  description="The page you requested does not exist."
  brand={content.brand}
  nav={content.nav}
  locale="en"
  homeHref="/en/"
  ctaLabel={content.hero.ctaLabel}
  ctaHref={content.hero.ctaHref}
  pageTone="inner"
>
  <section class="px-6 pb-24 pt-44 lg:px-10">
    <div class="mx-auto max-w-7xl rounded-3xl border border-white/10 bg-white/[0.03] p-10">
      <p class="text-sm uppercase tracking-[0.2em] text-white/55">404</p>
      <h1 class="mt-3 text-5xl text-white">Page not found</h1>
      <p class="mt-5 max-w-2xl text-white/70">The route you requested does not exist or has changed.</p>
      <a href="/en/" class="mt-8 inline-flex rounded-full border border-white/30 px-5 py-2 text-sm text-white transition hover:bg-white hover:text-black">
        Back to home
      </a>
    </div>
  </section>
</SiteScaffold>
