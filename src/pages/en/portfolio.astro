---
import SiteScaffold from '@/components/layout/SiteScaffold.astro';
import BrandStripSection from '@/components/sections/BrandStripSection.astro';
import ContactSection from '@/components/sections/ContactSection.astro';
import PageHeader from '@/components/sections/PageHeader.astro';
import PortfolioSection from '@/components/sections/PortfolioSection.astro';
import { createContentProvider } from '@/lib/content';

const provider = createContentProvider();
const content = await provider.getMarketingContent('en');
---

<SiteScaffold
  title={`${content.brand} | Portfolio`}
  description="Selected projects that showcase art direction, visual language, and production consistency."
  brand={content.brand}
  nav={content.nav}
  locale="en"
  homeHref="/en/"
  ctaLabel={content.hero.ctaLabel}
  ctaHref={content.hero.ctaHref}
  pageTone="inner"
>
  <PageHeader
    eyebrow="Editorial navigation"
    title="Portfolio"
    subtitle="Selected work that reflects craft, visual consistency, and storytelling quality."
  />
  <PortfolioSection portfolio={content.portfolio} />
  <BrandStripSection brands={content.brands} />
  <ContactSection contact={content.contact} nav={content.nav} />
</SiteScaffold>
