---
import SiteScaffold from '@/components/layout/SiteScaffold.astro';
import ArchiveGridSection from '@/components/sections/ArchiveGridSection.astro';
import ContactSection from '@/components/sections/ContactSection.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import MonumentalStatement from '@/components/sections/MonumentalStatement.astro';
import SelectedWorkSection from '@/components/sections/SelectedWorkSection.astro';
import ServicesSection from '@/components/sections/ServicesSection.astro';
import TestimonialSection from '@/components/sections/TestimonialSection.astro';
import { createContentProvider } from '@/lib/content';

const provider = createContentProvider();
const content = await provider.getMarketingContent('es');
---

<SiteScaffold
  title={`${content.brand} | Inicio`}
  description="Fotografía editorial con rendimiento web optimizado y navegación cinematográfica."
  brand={content.brand}
  locale="es"
  footer={content.footer}
  pageTone="home"
>
  <HeroSection hero={content.hero} />
  <MonumentalStatement about={content.about} aboutHref="/about/" />
  <ArchiveGridSection
    gallery={content.gallery}
    portfolio={content.portfolio}
    label={content.home.archiveLabel}
    linkLabel={content.home.archiveLinkLabel}
    linkHref="/portfolio/"
  />
  <ServicesSection
    services={content.services}
    sectionLabel={content.home.servicesLabel}
    indexLabel={content.home.servicesIndexLabel}
  />
  <SelectedWorkSection
    portfolio={content.portfolio}
    label={content.home.workLabel}
    title={content.home.workTitle}
    portfolioHref="/portfolio/"
  />
  <TestimonialSection testimonial={content.testimonials[1]} />
  <ContactSection contact={content.contact} />
</SiteScaffold>
