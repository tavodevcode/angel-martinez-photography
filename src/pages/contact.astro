---
import SiteScaffold from '@/components/layout/SiteScaffold.astro';
import ContactSection from '@/components/sections/ContactSection.astro';
import PageHeader from '@/components/sections/PageHeader.astro';
import { createContentProvider } from '@/lib/content';

const provider = createContentProvider();
const content = await provider.getMarketingContent();
---

<SiteScaffold
  title={`${content.brand} | Contacto`}
  description="Contáctanos para planear tu próxima sesión de fotos editorial o comercial."
  brand={content.brand}
  nav={content.nav}
  pageTone="inner"
>
  <PageHeader
    title="Contacto"
    subtitle="Cuéntanos el tipo de sesión, fechas y objetivo creativo. Te proponemos alcance, tiempos y producción."
  />
  <ContactSection contact={content.contact} nav={content.nav} />
</SiteScaffold>
