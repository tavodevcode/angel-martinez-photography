---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { Locale, PortfolioUiContent } from '@/lib/content/types';

interface Props {
  album: CollectionEntry<'albums'>;
  locale: Locale;
  backHref: string;
  backLabel: string;
  nextAlbum: CollectionEntry<'albums'>;
  nextHref: string;
  ui: PortfolioUiContent;
}

const { album, locale, backHref, backLabel, nextAlbum, nextHref, ui } = Astro.props;
const { title, description, category, dateLabel, cover, coverAlt, photos } = album.data;

// Referencia y metadatos de cámara decorativos, como en el diseño (no se traducen).
const refCode = `REF. AMP-${String(2500 + album.data.order).padStart(4, '0')}`;
const photoMeta = 'PL. 07 — 85MM · F/1.8 · ISO 800';

const facts = [
  { key: ui.dateKey, value: dateLabel[locale] },
  { key: ui.categoryKey, value: category[locale] },
  { key: ui.deliveryKey, value: `${photos.length + 1} ${ui.piecesUnit}` },
  { key: ui.directionKey, value: 'Angel Martinez' },
];

interface GridPiece {
  src: (typeof photos)[number]['src'];
  alt: string;
  heightClass: string;
  meta?: string;
  caption?: string;
}

const heightClasses = [
  'h-[280px] lg:h-[420px]',
  'h-[220px] lg:h-[300px]',
  'h-[260px] lg:h-[380px]',
  'h-[200px] lg:h-[260px]',
  'h-[280px] lg:h-[400px]',
  'h-[220px] lg:h-[300px]',
];

const columns: GridPiece[][] = [[], [], []];
photos.forEach((photo, index) => {
  columns[index % 3].push({
    src: photo.src,
    alt: photo.alt[locale],
    heightClass: heightClasses[index % heightClasses.length],
    meta: index === 1 ? photoMeta : undefined,
    caption: index === 0 ? photo.alt[locale] : undefined,
  });
});
---

<article aria-label={title[locale]}>
  <div class="flex flex-wrap items-center justify-between gap-3 px-6 pb-3 pt-28 lg:px-16 lg:pt-32">
    <a
      href={backHref}
      data-astro-prefetch="viewport"
      class="font-caption text-[11px] uppercase tracking-[0.2em] text-muted transition hover:text-white"
    >
      &larr; {backLabel} / {category[locale]}
    </a>
    <p class="font-meta text-[10px] uppercase tracking-[0.14em] text-muted">{refCode}</p>
  </div>

  <section
    transition:name={`album-${album.id}`}
    class="relative flex h-[min(700px,80svh)] flex-col justify-between overflow-hidden"
    aria-label={coverAlt[locale]}
  >
    <Picture
      src={cover}
      alt={coverAlt[locale]}
      widths={[768, 1280, 1920]}
      sizes="100vw"
      formats={['avif', 'webp']}
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/30" aria-hidden="true"></div>

    <div class="relative z-10 flex items-start justify-between gap-4 px-6 pt-9 lg:px-12">
      <p class="font-caption text-[11px] uppercase tracking-[0.24em] text-white">{category[locale]}</p>
      <p class="hidden font-caption text-[11px] uppercase tracking-[0.24em] text-white sm:block">{dateLabel[locale]}</p>
    </div>

    <div class="relative z-10 flex justify-center overflow-hidden">
      <h1 data-rise class="vt-page-title whitespace-nowrap text-center font-display text-[13.9vw] uppercase leading-[0.84] text-white">
        {title[locale]}
      </h1>
    </div>
  </section>

  <div class="grid grid-cols-2 gap-x-6 gap-y-8 px-6 py-10 lg:flex lg:items-start lg:justify-between lg:px-16">
    {facts.map((fact) => (
      <div class="flex flex-col gap-2">
        <p class="font-caption text-[10px] uppercase tracking-[0.2em] text-muted">{fact.key}</p>
        <p class="font-meta text-[13px] uppercase text-white">{fact.value}</p>
      </div>
    ))}
  </div>

  {photos.length > 0 && (
    <div class="grid grid-cols-1 gap-6 px-6 pb-[90px] pt-6 sm:grid-cols-3 lg:px-16">
      {columns.map((column) => (
        <div class="flex flex-col gap-6">
          {column.map((piece, pieceIndex) => (
            <figure data-reveal data-zoom class="flex flex-col gap-3" style={`--reveal-delay:${pieceIndex * 80}ms`}>
              <div class={`relative overflow-hidden rounded-xl ${piece.meta ? 'shadow-[0_12px_24px_rgba(0,0,0,0.7)]' : ''} ${piece.heightClass}`}>
                <Picture
                  src={piece.src}
                  alt={piece.alt}
                  widths={[420, 680, 920]}
                  sizes="(max-width: 640px) 100vw, 33vw"
                  formats={['avif', 'webp']}
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
                {piece.meta && (
                  <div class="absolute inset-x-0 bottom-0 flex items-center justify-between bg-black/65 px-4 py-2.5">
                    <span class="font-meta text-[10px] tracking-[0.12em] text-white">{piece.meta}</span>
                  </div>
                )}
              </div>
              {piece.caption && (
                <figcaption class="font-caption text-[10px] uppercase tracking-[0.18em] text-muted">
                  {piece.caption}
                </figcaption>
              )}
            </figure>
          ))}
        </div>
      ))}
    </div>
  )}

  <div data-reveal class="flex flex-col items-center gap-[18px] px-6 py-[90px] lg:py-[130px]">
    <p class="w-[560px] max-w-full text-center font-body text-[19px] font-medium leading-[1.7] text-white lg:text-[21px]">
      {description[locale]}
    </p>
    <p class="font-caption text-[10px] uppercase tracking-[0.22em] text-muted">
      {title[locale]} — {dateLabel[locale]}
    </p>
  </div>

  <a href={nextHref} data-astro-prefetch="viewport" class="group flex flex-col items-center gap-4 pb-10 pt-5">
    <p class="font-caption text-[11px] uppercase tracking-[0.24em] text-muted">{ui.nextAlbumLabel}</p>
    <div class="flex w-full justify-center overflow-hidden">
      <p data-rise class="whitespace-nowrap text-center font-display text-[19.4vw] uppercase leading-[0.84] text-white transition duration-300 group-hover:text-muted">
        {nextAlbum.data.title[locale]}
      </p>
    </div>
  </a>
</article>
