---
import { Picture } from 'astro:assets';
import type { GalleryItem } from '@/lib/content/types';

interface Props {
  gallery: GalleryItem[];
}

const { gallery } = Astro.props;
const [first, second, third] = gallery;
---

<section class="section-rule px-6 py-16 lg:px-10 lg:py-24">
  <div class="mx-auto w-full max-w-[1440px]">
    <div class="relative min-h-[620px]">
      <div class="w-[88%] overflow-hidden lg:w-[78%]">
        <Picture
          src={first.image}
          alt={first.alt}
          widths={[780, 1180, 1560]}
          sizes="(max-width: 1024px) 82vw, 55vw"
          formats={['avif', 'webp']}
          loading="lazy"
          class="h-auto w-full object-cover"
        />
      </div>

      <div class="absolute right-[2%] top-[40%] w-[42%] overflow-hidden border border-white/10 lg:w-[34%]">
        <Picture
          src={second.image}
          alt={second.alt}
          widths={[440, 700, 980]}
          sizes="(max-width: 1024px) 42vw, 26vw"
          formats={['avif', 'webp']}
          loading="lazy"
          class="h-auto w-full object-cover"
        />
      </div>

      <div class="absolute -bottom-6 left-[8%] w-[52%] overflow-hidden border border-white/10 lg:left-[10%] lg:w-[42%]">
        <Picture
          src={third.image}
          alt={third.alt}
          widths={[640, 980, 1300]}
          sizes="(max-width: 1024px) 52vw, 30vw"
          formats={['avif', 'webp']}
          loading="lazy"
          class="h-auto w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
