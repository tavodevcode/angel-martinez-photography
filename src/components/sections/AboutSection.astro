---
import { Picture } from 'astro:assets';
import { getLocaleFromPath } from '@/lib/i18n';
import type { AboutContent } from '@/lib/content/types';

interface Props {
  about: AboutContent;
}

const { about } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const sectionLabel = locale === 'en' ? '* About' : '* Nosotros';
const words = about.title.split(' ');
---

<section class="section-rule px-6 py-16 lg:px-10 lg:py-24">
  <div class="mx-auto grid w-full max-w-[1440px] gap-10 lg:grid-cols-[1.1fr_1fr] lg:gap-16">
    <div>
      <p class="mb-8 text-[10px] uppercase tracking-[0.22em] text-white/55">{sectionLabel}</p>
      <h2 class="font-display text-[58px] font-semibold leading-[0.92] text-white sm:text-[74px] lg:text-[92px]">
        {words.map((word) => <span class="mr-[0.18em] inline-block">{word}</span>)}
      </h2>
    </div>

    <div class="relative min-h-[560px]">
      <div class="absolute left-0 top-0 w-[54%] overflow-hidden">
        <Picture
          src={about.imageA}
          alt="Artistic portrait"
          widths={[360, 640, 860]}
          sizes="(max-width: 1024px) 58vw, 26vw"
          formats={['avif', 'webp']}
          loading="lazy"
          class="h-auto w-full object-cover"
        />
      </div>

      <div class="absolute right-0 top-14 w-[64%] overflow-hidden">
        <Picture
          src={about.imageB}
          alt="Cinematic portrait"
          widths={[420, 700, 980]}
          sizes="(max-width: 1024px) 62vw, 28vw"
          formats={['avif', 'webp']}
          loading="lazy"
          class="h-auto w-full object-cover"
        />
      </div>

      <p class="absolute bottom-0 right-0 max-w-[82%] text-right text-sm leading-relaxed text-white/70 lg:max-w-[70%]">
        {about.paragraph}
      </p>
    </div>
  </div>
</section>
