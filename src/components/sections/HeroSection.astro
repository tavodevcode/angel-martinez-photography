---
import { Image } from 'astro:assets';
import { getLocaleFromPath } from '@/lib/i18n';
import type { HeroContent } from '@/lib/content/types';

interface Props {
  hero: HeroContent;
}

const { hero } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const scrollCopy = locale === 'en' ? 'scroll down' : 'desliza';
---

<section class="section-rule relative overflow-hidden px-6 pb-16 pt-28 lg:px-10 lg:pb-20 lg:pt-32">
  <div class="mx-auto w-full max-w-[1440px]">
    <div class="grid min-h-[72vh] grid-cols-1 items-end gap-10 lg:grid-cols-[1fr_360px] lg:gap-12">
      <div class="relative pb-20 lg:pb-14">
        <p class="mb-4 text-[10px] uppercase tracking-[0.24em] text-white/55">{hero.eyebrow}</p>
        <h1 class="font-display text-[31vw] font-semibold leading-[0.9] tracking-tight text-white sm:text-[190px] lg:text-[270px]">
          {hero.title}
        </h1>

        <div class="absolute left-1/2 top-[60%] w-[56%] -translate-x-1/2 -translate-y-1/2 md:w-[50%] lg:w-[42%]">
          <div class="relative overflow-hidden border border-white/20 bg-black">
            <Image
              src={hero.image}
              alt="Hero eye"
              widths={[500, 800, 1200]}
              sizes="(max-width: 1024px) 60vw, 30vw"
              format="avif"
              loading="eager"
              fetchpriority="high"
              class="relative z-10 h-auto w-full object-cover"
            />
          </div>
        </div>

        <div class="hidden lg:block">
          <div class="absolute bottom-0 left-0 flex items-center gap-3 text-white">
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-white/45 text-xs">↓</span>
            <span class="font-display text-[46px] font-semibold leading-none">{scrollCopy}</span>
          </div>
        </div>
      </div>

      <div class="pb-12 lg:pb-16 lg:text-right">
        <p class="font-display text-2xl italic text-white/92">{hero.subtitle}</p>
        <p class="mt-3 max-w-sm text-sm leading-relaxed text-white/64 lg:ml-auto">{hero.description}</p>
      </div>
    </div>
  </div>
</section>
