---
interface Props {
  title: string;
  subtitle: string;
  eyebrow?: string;
}

const { title, subtitle, eyebrow = 'Navegacion editorial' } = Astro.props;
---

<section class="px-6 pb-10 pt-36 lg:px-10 lg:pt-44">
  <div class="mx-auto w-full max-w-7xl">
    <p class="text-xs uppercase tracking-[0.24em] text-white/55">{eyebrow}</p>
    <h1 class="vt-page-title mt-4 text-5xl text-white sm:text-6xl lg:text-7xl">{title}</h1>
    <p class="mt-4 max-w-3xl text-white/70">{subtitle}</p>
  </div>
</section>
