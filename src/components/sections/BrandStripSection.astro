---
interface Props {
  brands: string[];
}

const { brands } = Astro.props;
const midpoint = Math.ceil(brands.length / 2);
const rowA = brands.slice(0, midpoint);
const rowB = brands.slice(midpoint);
---

<section class="section-rule px-6 py-14 lg:px-10">
  <div class="mx-auto w-full max-w-[1440px] space-y-8">
    <div class="grid grid-cols-2 gap-x-8 gap-y-4 md:grid-cols-5">
      {rowA.map((brand) => <span class="text-center text-xs uppercase tracking-[0.14em] text-white/62">{brand}</span>)}
    </div>
    <div class="grid grid-cols-2 gap-x-8 gap-y-4 md:grid-cols-4">
      {rowB.map((brand) => <span class="text-center text-xs uppercase tracking-[0.14em] text-white/44">{brand}</span>)}
    </div>
  </div>
</section>
