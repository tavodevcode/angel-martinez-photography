---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { Locale, ServicesUiContent } from '@/lib/content/types';

interface Props {
  service: CollectionEntry<'services'>;
  locale: Locale;
  backHref: string;
  backLabel: string;
  packagesTitle: string;
  ctaLabel: string;
  ctaHref: string;
  ui: ServicesUiContent;
  email: string;
  phone: string;
}

const { service, locale, backHref, backLabel, packagesTitle, ctaLabel, ctaHref, ui, email, phone } = Astro.props;
const { title, description, image, imageAlt, packages } = service.data;
const hasPackages = packages.length > 0;
const orderLabel = String(service.data.order).padStart(2, '0');
---

<section aria-label={title[locale]}>
  <!-- Hero nocturno -->
  <div
    transition:name={`service-${service.id}`}
    class="relative flex min-h-[92svh] flex-col justify-between gap-12 overflow-hidden pb-12 pt-28 lg:pt-32"
  >
    <Picture
      src={image}
      alt={imageAlt[locale]}
      widths={[768, 1280, 1920]}
      sizes="100vw"
      formats={['avif', 'webp']}
      loading="eager"
      fetchpriority="high"
      class="anim-kenburns absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/55" aria-hidden="true"></div>

    <div class="relative z-10 flex items-center justify-between px-6 lg:px-12">
      <a
        href={backHref}
        data-astro-prefetch="viewport"
        class="font-caption text-[11px] font-semibold uppercase tracking-[0.22em] text-white transition hover:text-muted"
      >
        &larr; {backLabel}
      </a>
      <p class="font-caption text-[11px] font-semibold uppercase tracking-[0.22em] text-muted">
        {hasPackages ? ui.detailPackagesTag : ui.detailStudioTag}
      </p>
    </div>

    <div data-reveal class="relative z-10 flex flex-col items-center gap-6 px-6">
      <h1 class="vt-page-title text-center font-display text-[clamp(52px,10.4vw,164px)] uppercase leading-[0.9] text-white">
        {title[locale]}
      </h1>
      <p class="w-[640px] max-w-full text-center font-body text-[18px] font-medium leading-[1.6] text-white">
        {description[locale]}
      </p>
      <a
        href={ctaHref}
        data-astro-prefetch="viewport"
        class="inline-flex items-center gap-3.5 rounded-full bg-white px-7 py-[15px] transition hover:bg-accent"
      >
        <span class="h-2 w-2 rounded-full bg-[#FF9800]" aria-hidden="true"></span>
        <span class="font-caption text-[12px] font-bold uppercase tracking-[0.14em] text-black">{ctaLabel}</span>
      </a>
    </div>

    <div class="relative z-10 flex flex-col gap-2 px-6 sm:flex-row sm:items-center sm:justify-between lg:px-12">
      <p class="font-caption text-[11px] font-semibold uppercase tracking-[0.2em] text-muted">{ui.detailMetaLeft}</p>
      <p class="font-caption text-[11px] font-semibold uppercase tracking-[0.2em] text-muted">{ui.detailMetaRight}</p>
    </div>
  </div>

  {hasPackages && (
    <>
      <div class="h-px w-full bg-white/12" aria-hidden="true"></div>

      <!-- Intro paquetes -->
      <div class="flex flex-col gap-10 px-6 pb-16 pt-24 lg:flex-row lg:items-end lg:gap-24 lg:px-20 lg:pb-24 lg:pt-[118px]">
        <div class="flex flex-1 flex-col gap-4">
          <p class="font-caption text-[11px] font-semibold uppercase tracking-[0.22em] text-muted">
            {packagesTitle} / {title[locale]}
          </p>
          <h2 class="max-w-[720px] font-display text-[clamp(36px,5.2vw,76px)] uppercase leading-[0.92] text-white">
            {ui.packagesHeadline}
          </h2>
        </div>
        <div class="flex w-full flex-col gap-5 lg:w-[460px] lg:shrink-0">
          <p class="font-body text-[17px] leading-[1.65] text-muted">{ui.packagesIntro}</p>
          <p class="font-caption text-[11px] font-semibold uppercase tracking-[0.22em] text-muted">{ui.packagesNote}</p>
        </div>
      </div>

      <div class="h-px w-full bg-white/12" aria-hidden="true"></div>

      <!-- Grid de paquetes -->
      <div class="grid md:grid-cols-3">
        {packages.map((pkg, index) => (
          <article
            aria-label={pkg.name[locale]}
            data-reveal
            style={`--reveal-delay:${index * 90}ms`}
            class="flex flex-col gap-6 border-b border-white/12 px-6 py-14 transition-colors duration-300 last:border-b-0 hover:bg-white/[0.03] md:border-b-0 md:border-r md:px-10 md:py-[72px] md:last:border-r-0"
          >
            <p class="font-caption text-[11px] font-semibold uppercase tracking-[0.22em] text-muted">
              {String(index + 1).padStart(2, '0')} / {packagesTitle}
            </p>
            <h3 class="font-display text-[clamp(30px,3vw,44px)] uppercase leading-[0.95] text-white">
              {pkg.name[locale]}
            </h3>
            <ul class="flex flex-col">
              {pkg.features[locale].map((feature) => (
                <li class="border-t border-white/12 py-3 font-body text-[15px] leading-[1.5] text-muted first:border-t-0 first:pt-0">
                  {feature}
                </li>
              ))}
            </ul>
            <p class="mt-auto inline-flex w-fit rounded-[8px] border border-white/40 px-[18px] py-3 font-caption text-[11px] font-semibold uppercase tracking-[0.18em] text-white">
              {ui.priceFromLabel} {pkg.price}
            </p>
          </article>
        ))}
      </div>
    </>
  )}

  <div class="h-px w-full bg-white/12" aria-hidden="true"></div>

  <!-- Enfoque + imagen editorial -->
  <div class="flex flex-col gap-14 px-6 py-24 lg:flex-row lg:items-center lg:gap-24 lg:px-20 lg:py-[130px]">
    <div data-reveal data-zoom class="relative w-full overflow-hidden rounded-[12px] border border-white/20 shadow-[0_12px_24px_rgba(0,0,0,0.7)] lg:w-[510px] lg:shrink-0">
      <Picture
        src={image}
        alt={imageAlt[locale]}
        widths={[520, 820, 1100]}
        sizes="(max-width: 1024px) 100vw, 510px"
        formats={['avif', 'webp']}
        class="h-[380px] w-full object-cover sm:h-[520px]"
      />
      <div class="absolute inset-x-0 bottom-0 flex items-center justify-between bg-black/70 px-5 py-[18px]">
        <p class="font-caption text-[11px] font-semibold uppercase tracking-[0.18em] text-white">{title[locale]}</p>
        <p class="font-meta text-[10px] tracking-[0.12em] text-muted">SRV. {orderLabel}</p>
      </div>
    </div>
    <div class="flex flex-1 flex-col items-start gap-7 lg:gap-8">
      <p class="font-caption text-[11px] font-semibold uppercase tracking-[0.22em] text-muted">{ui.approachLabel}</p>
      <h2 class="font-display text-[clamp(38px,4.8vw,68px)] uppercase leading-[0.95] text-white">
        {ui.approachTitle}
      </h2>
      <p class="max-w-[560px] font-body text-[18px] leading-[1.6] text-white">{ui.approachCopy}</p>
      <a
        href={ctaHref}
        data-astro-prefetch="viewport"
        class="rounded-[8px] border border-white/40 px-[18px] py-3 font-caption text-[11px] font-semibold uppercase tracking-[0.18em] text-white transition hover:bg-white hover:text-black"
      >
        {ctaLabel}
      </a>
    </div>
  </div>

  <div class="h-px w-full bg-white/12" aria-hidden="true"></div>

  <!-- Cierre agenda -->
  <div class="flex flex-col items-center gap-8 overflow-hidden px-6 pb-16 pt-24 lg:pb-24 lg:pt-[120px]">
    <p class="font-caption text-[11px] font-semibold uppercase tracking-[0.26em] text-muted">
      {ui.detailClosingEyebrow}
    </p>
    <h2 class="text-center font-display text-[clamp(44px,11vw,160px)] uppercase leading-[0.95] text-white">
      {ui.detailClosingTitle}
    </h2>
    <p class="w-[620px] max-w-full text-center font-body text-[18px] font-medium leading-[1.6] text-white">
      {ui.detailClosingCopy}
    </p>
    <a
      href={ctaHref}
      data-astro-prefetch="viewport"
      class="inline-flex items-center gap-3.5 rounded-full bg-white px-7 py-[15px] transition hover:bg-accent"
    >
      <span class="h-2 w-2 rounded-full bg-[#FF9800]" aria-hidden="true"></span>
      <span class="font-caption text-[12px] font-bold uppercase tracking-[0.14em] text-black">{ctaLabel}</span>
    </a>
    <p class="text-center font-body text-[16px] text-muted">{email} · {phone}</p>
  </div>
</section>
