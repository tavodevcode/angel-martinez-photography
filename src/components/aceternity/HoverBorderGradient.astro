---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a
  href={href}
  class="group relative inline-flex items-center justify-center overflow-hidden rounded-full p-[1px]"
>
  <span class="absolute inset-0 bg-[linear-gradient(120deg,#ffffff1c,#ffffff,#ffffff1c)] opacity-70 transition duration-300 group-hover:opacity-100" />
  <span class="relative rounded-full bg-black px-6 py-2.5 text-sm text-white transition group-hover:bg-white group-hover:text-black">
    {label}
  </span>
</a>
