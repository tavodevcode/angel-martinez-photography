---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<article class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] p-6">
  <div class="pointer-events-none absolute inset-0 opacity-0 transition duration-300 group-hover:opacity-100">
    <div class="absolute -left-20 top-0 h-56 w-56 rounded-full bg-white/15 blur-3xl" />
  </div>
  <h3 class="relative z-10 font-display text-3xl">{title}</h3>
  <p class="relative z-10 mt-3 text-sm leading-relaxed text-white/70">{description}</p>
</article>
