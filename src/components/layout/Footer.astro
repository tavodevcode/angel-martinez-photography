---
interface Props {
  brand: string;
}

const year = new Date().getFullYear();
const { brand } = Astro.props;
---

<footer class="section-rule px-6 py-5 lg:px-10">
  <div class="mx-auto flex w-full max-w-[1440px] items-center justify-between gap-4 text-xs text-white/45">
    <p>© {year} {brand}. All rights reserved.</p>
    <a href="/contact" class="transition hover:text-white/70">Privacy Policy</a>
  </div>
</footer>
