---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/layout/Footer.astro';
import FloatingNav from '@/components/layout/FloatingNav';
import type { FooterContent, Locale } from '@/lib/content/types';

interface Props {
  title: string;
  description: string;
  brand: string;
  locale: Locale;
  footer: FooterContent;
  pageTone?: 'home' | 'inner';
}

const { title, description, brand, locale, footer } = Astro.props;
const windowTransition = {
  forwards: {
    old: { name: 'vt-window-out', duration: '0.34s', easing: 'cubic-bezier(0.33, 0, 0.67, 1)', fillMode: 'both' },
    new: { name: 'vt-window-in', duration: '0.34s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'both' },
  },
  backwards: {
    old: { name: 'vt-window-out', duration: '0.34s', easing: 'cubic-bezier(0.33, 0, 0.67, 1)', fillMode: 'both' },
    new: { name: 'vt-window-in', duration: '0.34s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'both' },
  },
};
---

<BaseLayout title={title} description={description} locale={locale}>
  <div transition:persist>
    <FloatingNav client:load brand={brand} initialPath={Astro.url.pathname} />
  </div>
  <div transition:persist aria-hidden="true" class="pointer-events-none fixed inset-0 z-10">
    <div class="absolute inset-y-0 left-1/2 w-px -translate-x-1/2 bg-white/10" />
  </div>
  <main transition:animate={windowTransition} class="soft-grid relative">
    <slot />
  </main>
  <div transition:persist>
    <Footer brand={brand} locale={locale} footer={footer} />
  </div>
</BaseLayout>
