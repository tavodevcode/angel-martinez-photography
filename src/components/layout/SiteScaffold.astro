---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/layout/Footer.astro';
import FloatingNav from '@/components/layout/FloatingNav';
import type { NavItem } from '@/lib/content/types';

interface Props {
  title: string;
  description: string;
  brand: string;
  nav: NavItem[];
  pageTone?: 'home' | 'inner';
}

const { title, description, brand, nav, pageTone = 'inner' } = Astro.props;
const homeDirectionalTransition = {
  forwards: {
    old: { name: 'vt-cinema-out', duration: '0.34s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'both' },
    new: { name: 'vt-snap-in', duration: '0.17s', easing: 'cubic-bezier(0.16, 1, 0.3, 1)', fillMode: 'both' },
  },
  backwards: {
    old: { name: 'vt-snap-out', duration: '0.15s', easing: 'cubic-bezier(0.4, 0, 1, 1)', fillMode: 'both' },
    new: { name: 'vt-snap-in', duration: '0.15s', easing: 'cubic-bezier(0.16, 1, 0.3, 1)', fillMode: 'both' },
  },
};

const innerDirectionalTransition = {
  forwards: {
    old: { name: 'vt-snap-out', duration: '0.22s', easing: 'cubic-bezier(0.4, 0, 1, 1)', fillMode: 'both' },
    new: { name: 'vt-cinema-in', duration: '0.3s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'both' },
  },
  backwards: {
    old: { name: 'vt-snap-out', duration: '0.16s', easing: 'cubic-bezier(0.4, 0, 1, 1)', fillMode: 'both' },
    new: { name: 'vt-snap-in', duration: '0.16s', easing: 'cubic-bezier(0.16, 1, 0.3, 1)', fillMode: 'both' },
  },
};

const pageTransition = pageTone === 'home' ? homeDirectionalTransition : innerDirectionalTransition;
---

<BaseLayout title={title} description={description}>
  <div transition:persist>
    <FloatingNav client:idle brand={brand} links={nav} />
  </div>
  <div transition:persist aria-hidden="true" class="pointer-events-none fixed inset-0 z-10">
    <div class="absolute inset-y-0 left-1/2 w-px -translate-x-1/2 bg-white/10" />
  </div>
  <main transition:animate={pageTransition} class="soft-grid relative">
    <slot />
  </main>
  <div transition:persist>
    <Footer brand={brand} />
  </div>
</BaseLayout>
